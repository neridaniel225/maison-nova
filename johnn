}
function rmSz(i){sList.splice(i,1);renderSzTags();}

/* ════ CATEGORY FORM ════ */
function openCatModal(){
  editCId=null;
  document.getElementById('catModalTitle').textContent='Nouvelle Catégorie';
  document.getElementById('fcN').value='';
  document.getElementById('fcE').value='';
  document.getElementById('fcImg').value='';
  document.getElementById('fcCol').value='#F7F7F5';
  document.getElementById('catModal').classList.add('on');
}
function editCat(id){
  const c=CATS.find(x=>x.id===id);if(!c)return;
  editCId=id;
  document.getElementById('catModalTitle').textContent='Modifier la Catégorie';
  document.getElementById('fcN').value=c.name;
  document.getElementById('fcE').value=c.emoji||'';
  document.getElementById('fcImg').value=c.img||'';
  document.getElementById('fcCol').value=c.color||'#F7F7F5';
  document.getElementById('catModal').classList.add('on');
}
function delCat(id){
  if(!confirm('Supprimer cette catégorie ?'))return;
  CATS=CATS.filter(c=>c.id!==id);
  buildAdmCats();buildCatCircles();buildMmCats();buildCarousels();
  toast('Catégorie supprimée');
}
function saveCat(){
  const name=document.getElementById('fcN').value.trim();if(!name){alert('Nom requis');return;}
  const d={id:editCId||nxCId++,name,emoji:document.getElementById('fcE').value.trim()||'📦',img:document.getElementById('fcImg').value.trim(),color:document.getElementById('fcCol').value};
  if(editCId){const i=CATS.findIndex(c=>c.id===editCId);if(i>-1)CATS[i]=d;}else CATS.push(d);
  closeCatModal();
  buildAdmCats();buildCatCircles();buildMmCats();buildCarousels();
  buildSbCats();populateCatSel();syncStats();
  toast(editCId?'Catégorie mise à jour !':'Catégorie créée !');
}
function closeCatModal(e){
  if(e&&e.target!==document.getElementById('catModal'))return;
  document.getElementById('catModal').classList.remove('on');
}
function handleCatUp(input){
  const f=input.files[0];if(!f)return;
  const r=new FileReader();r.onload=e=>document.getElementById('fcImg').value=e.target.result;r.readAsDataURL(f);
}
</script>
