/* Forms */
#admModal{
  position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,.65);
  display:none;align-items:center;justify-content:center;padding:1rem;
}
#admModal.on{display:flex;animation:fadeIn .2s ease}
.am-box{
  background:white;border-radius:var(--r3);
  width:100%;max-width:560px;max-height:90vh;overflow-y:auto;
  animation:fadeUp .3s var(--ease);
}
.am-hd{
  display:flex;align-items:center;justify-content:space-between;
  padding:1.2rem 1.4rem;border-bottom:1px solid var(--mist);
  position:sticky;top:0;background:white;z-index:1;
}
.am-hd h3{font-size:.95rem;font-weight:700}
.am-x{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--mid);cursor:pointer;transition:all .2s}
.am-x:hover{background:var(--fog);color:var(--ink)}
.am-body{padding:1.4rem;display:flex;flex-direction:column;gap:.9rem}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:.9rem}
.fg{display:flex;flex-direction:column;gap:.35rem}
.fg label{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:var(--pale)}
.fg input,.fg select,.fg textarea{
  border:1.5px solid var(--mist);border-radius:var(--r);
  padding:.6rem .85rem;font-size:.82rem;color:var(--ink);
  outline:none;transition:border-color .2s;background:var(--smoke);
}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--warm);background:white}
.fg textarea{min-height:72px;resize:vertical}
.fg .hint{font-size:.62rem;color:var(--pale)}

/* Upload zone */
.upload-zone{
  border:1.5px dashed var(--mist);border-radius:var(--r2);
  padding:1.2rem;text-align:center;cursor:pointer;transition:border-color .2s;background:var(--smoke);
}
.upload-zone:hover{border-color:var(--warm)}
.upload-zone input[type=file]{display:none}
.ph-prevs{display:flex;gap:6px;flex-wrap:wrap;margin-top:.6rem}
.ph-prev{position:relative;width:64px;height:78px;border-radius:var(--r);overflow:hidden;border:1px solid var(--mist)}
.ph-prev img{width:100%;height:100%;object-fit:cover}
.ph-rm{
  position:absolute;top:2px;right:2px;width:17px;height:17px;
  background:rgba(0,0,0,.6);color:white;border-radius:50%;
  font-size:.6rem;display:flex;align-items:center;justify-content:center;cursor:pointer;
}
.ph-rm:hover{background:var(--warm)}

/* Tag inputs */
.tag-wrap{
  display:flex;align-items:center;gap:5px;flex-wrap:wrap;
  padding:.45rem .7rem;border:1.5px solid var(--mist);border-radius:var(--r);
  background:var(--smoke);transition:border-color .2s;
}
.tag-wrap:focus-within{border-color:var(--warm);background:white}
.tchip{
  display:inline-flex;align-items:center;gap:4px;
  background:var(--ink);color:white;border-radius:2px;
  padding:2px 7px;font-size:.65rem;font-weight:700;
}
.tchip button{background:none;color:rgba(255,255,255,.5);font-size:.6rem;line-height:1;transition:color .2s}
.tchip button:hover{color:white}
.tchip-c{background:var(--warm)}
