<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>MAISON NOVA — Boutique Mode</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&family=Outfit:wght@200;300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
/* ════════════════════════════════════════
   DESIGN SYSTEM — NOIR & BLANC
════════════════════════════════════════ */
:root{
  --ink:#0C0C0C;
  --ink2:#1A1A1A;
  --ink3:#2E2E2E;
  --smoke:#F7F7F5;
  --fog:#EFEFED;
  --mist:#E8E8E6;
  --chalk:#FAFAF8;
  --white:#FFFFFF;
  --mid:#888884;
  --pale:#C4C4C0;
  /* Warm accent for promo/annonces */
  --warm:#D4621A;
  --warm2:#E8A030;
  --warm3:#F2C96E;
  --warm-glow:rgba(212,98,26,.18);
  /* Functional */
  --r:6px;--r2:10px;--r3:14px;
  --ease:cubic-bezier(.16,1,.3,1);
  --ease2:cubic-bezier(.22,1,.36,1);
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px;scroll-behavior:smooth}
body{
  font-family:'Outfit',sans-serif;
  background:var(--chalk);color:var(--ink);
  overflow-x:hidden;line-height:1.6;
}
h1,h2,h3,h4{font-family:'Cormorant',serif;line-height:1.05}
img{display:block;width:100%;height:100%;object-fit:cover}
a{text-decoration:none;color:inherit}
button{cursor:pointer;font-family:inherit;border:none;background:none}
input,select,textarea{font-family:inherit}

/* ════ ANIMATIONS ════ */
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes autoScroll{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes cartPop{0%{transform:scale(1)}40%{transform:scale(1.6)}100%{transform:scale(1)}}
@keyframes slideRight{from{transform:translateX(110%)}to{transform:translateX(0)}}
@keyframes shimmer{0%{opacity:.4}50%{opacity:1}100%{opacity:.4}}
@keyframes heroFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes burgerTop{from{}to{transform:rotate(45deg) translate(4px,4px)}}
@keyframes burgerBot{from{}to{transform:rotate(-45deg) translate(4px,-4px)}}

.rev{opacity:0;transform:translateY(20px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.rev.in{opacity:1;transform:translateY(0)}
.rev.d1{transition-delay:.1s}.rev.d2{transition-delay:.18s}.rev.d3{transition-delay:.26s}.rev.d4{transition-delay:.34s}

/* ════════════════════════════════════════
   PROMO TICKER — warm accent
════════════════════════════════════════ */
#ticker{
  background:var(--ink);
  padding:9px 0;overflow:hidden;
  position:relative;z-index:200;
}
#ticker::before,#ticker::after{
  content:'';position:absolute;top:0;bottom:0;width:60px;z-index:1;
}
#ticker::before{left:0;background:linear-gradient(90deg,var(--ink),transparent)}
#ticker::after{right:0;background:linear-gradient(-90deg,var(--ink),transparent)}
.ticker-track{display:flex;gap:0;width:max-content;animation:ticker 28s linear infinite}
.ticker-item{
  display:inline-flex;align-items:center;gap:2rem;
  padding:0 2rem;
  font-size:.68rem;font-weight:600;letter-spacing:.16em;text-transform:uppercase;
  color:rgba(255,255,255,.55);white-space:nowrap;flex-shrink:0;
}
.ticker-item .t-hot{color:var(--warm2);font-weight:800}
.ticker-sep{
  color:var(--warm);font-size:.6rem;flex-shrink:0;
}

/* ════════════════════════════════════════
   NAV — Élégant, Raffiné
════════════════════════════════════════ */
#nav{
  position:sticky;top:0;z-index:500;
  background:rgba(250,250,248,.97);
  backdrop-filter:blur(20px) saturate(1.4);
  border-bottom:1px solid var(--mist);
  transition:border-color .3s,box-shadow .4s;
}
#nav.scrolled{
  box-shadow:0 4px 40px rgba(0,0,0,.07);
  border-color:rgba(0,0,0,.1);
}
.nav-wrap{
  max-width:1380px;margin:0 auto;
  display:grid;grid-template-columns:1fr auto 1fr;
  align-items:center;padding:0 2.2rem;
  height:68px;gap:1.5rem;
}

/* LEFT — Menu burger + liens */
.nav-left{display:flex;align-items:center;gap:1.8rem}
.burger{
  display:flex;flex-direction:column;gap:5px;
  padding:8px;margin:-8px;border-radius:var(--r);
  transition:background .2s;cursor:pointer;
}
.burger:hover{background:var(--fog)}
.burger span{
  display:block;height:1.5px;background:var(--ink);
  transition:transform .35s var(--ease),opacity .25s,width .3s;
  transform-origin:left center;
}
.burger span:nth-child(1){width:22px}
.burger span:nth-child(2){width:16px}
.burger span:nth-child(3){width:20px}
.burger.open span:nth-child(1){transform:rotate(40deg) translate(1px,-1px);width:22px}
.burger.open span:nth-child(2){opacity:0;transform:translateX(-8px)}
.burger.open span:nth-child(3){transform:rotate(-40deg) translate(1px,1px);width:22px}

.nav-links{display:flex;align-items:center;gap:2rem;list-style:none}
@media(max-width:860px){.nav-links{display:none}}
.nav-links a{
  font-size:.72rem;font-weight:500;letter-spacing:.12em;
  text-transform:uppercase;color:var(--mid);
  position:relative;padding-bottom:2px;transition:color .25s;
}
.nav-links a::after{
  content:'';position:absolute;bottom:0;left:0;right:0;
  height:1px;background:var(--ink);
  transform:scaleX(0);transform-origin:right;
  transition:transform .3s var(--ease);
}
.nav-links a:hover{color:var(--ink)}
.nav-links a:hover::after,.nav-links a.active::after{transform:scaleX(1);transform-origin:left}
.nav-links a.active{color:var(--ink)}

/* CENTER — Logo */
.nav-logo{
  display:flex;flex-direction:column;align-items:center;
  cursor:pointer;transition:opacity .3s;user-select:none;
}
.nav-logo:hover{opacity:.75}
.logo-name{
  font-family:'Cormorant',serif;
  font-size:1.55rem;font-weight:700;
  letter-spacing:.22em;text-transform:uppercase;
  color:var(--ink);line-height:1;
  /* Elegant border treatment */
  border-bottom:1px solid var(--ink);
  padding-bottom:1px;
}
.logo-sub{
  font-size:.52rem;font-weight:500;
  letter-spacing:.42em;text-transform:uppercase;
  color:var(--pale);margin-top:3px;
}

/* RIGHT — Icons */
.nav-right{display:flex;align-items:center;gap:.5rem;justify-content:flex-end}
.nav-icon{
  position:relative;width:40px;height:40px;border-radius:var(--r);
  display:flex;align-items:center;justify-content:center;
  color:var(--ink3);transition:all .2s;cursor:pointer;
}
.nav-icon:hover{background:var(--fog)}
.nav-icon svg{width:20px;height:20px;display:block}

/* Search inline expand */
.nav-search-wrap{
  display:flex;align-items:center;
  background:transparent;border-radius:var(--r);
  border:1px solid transparent;
  transition:all .3s var(--ease);overflow:hidden;
  max-width:40px;
}
.nav-search-wrap.expanded{
  background:var(--fog);border-color:var(--mist);
  max-width:240px;
}
.search-icon-btn{
  width:40px;height:40px;flex-shrink:0;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--ink3);transition:color .2s;
}
.search-icon-btn:hover{color:var(--ink)}
.nav-search-input{
  background:none;border:none;outline:none;
  font-size:.82rem;color:var(--ink);width:0;
  transition:width .3s var(--ease),padding .3s;
  padding:0;
}
.nav-search-wrap.expanded .nav-search-input{width:180px;padding:0 8px 0 0}
.nav-search-input::placeholder{color:var(--pale)}

/* Cart button */
.cart-icon{position:relative}
.cart-badge{
  position:absolute;top:6px;right:6px;
  width:15px;height:15px;border-radius:50%;
  background:var(--warm);color:white;
  font-size:.55rem;font-weight:800;
  display:flex;align-items:center;justify-content:center;
  opacity:0;transform:scale(0);
  transition:all .3s var(--ease2);
  border:1.5px solid var(--chalk);
  pointer-events:none;
}
.cart-badge.on{opacity:1;transform:scale(1)}
.cart-badge.pop{animation:cartPop .35s ease}

/* ════════════════════════════════════════
   MOBILE MENU OVERLAY
════════════════════════════════════════ */
#mobileMenu{
  position:fixed;inset:0;top:0;z-index:490;
  background:var(--ink);color:white;
  transform:translateX(-100%);transition:transform .5s var(--ease);
  padding:100px 3rem 3rem;
  display:flex;flex-direction:column;justify-content:space-between;
}
#mobileMenu.open{transform:translateX(0)}
.mm-links{display:flex;flex-direction:column;gap:0}
.mm-link{
  display:block;
  font-family:'Cormorant',serif;
  font-size:clamp(2.2rem,6vw,3.5rem);
  font-weight:600;color:rgba(255,255,255,.25);
  line-height:1.15;
  border-top:1px solid rgba(255,255,255,.06);
  padding:1rem 0;
  transition:color .25s,padding-left .3s;
  cursor:pointer;
}
.mm-link:hover,.mm-link.active{color:white;padding-left:.6rem}
.mm-link.active{color:var(--warm2)}
.mm-cats{display:flex;flex-wrap:wrap;gap:8px;margin-top:2rem}
.mm-cat{
  padding:6px 14px;border:1px solid rgba(255,255,255,.12);
  border-radius:100px;font-size:.68rem;font-weight:600;
  letter-spacing:.12em;text-transform:uppercase;
  color:rgba(255,255,255,.4);cursor:pointer;transition:all .2s;
}
.mm-cat:hover{border-color:var(--warm2);color:var(--warm2)}
.mm-bottom{color:rgba(255,255,255,.2);font-size:.72rem;letter-spacing:.1em}

/* ════════════════════════════════════════
   VIEWS
════════════════════════════════════════ */
.view{display:none}
.view.on{display:block;animation:fadeIn .2s ease}

/* ════════════════════════════════════════
   HERO — Éditorial noir/blanc
════════════════════════════════════════ */
.hero{
  display:grid;grid-template-columns:1fr 1fr;
  min-height:calc(100vh - 68px);
  background:var(--ink);
  overflow:hidden;
  position:relative;
}
.hero-left{
  padding:5rem 4rem;
  display:flex;flex-direction:column;justify-content:center;
  position:relative;
}
.hero-left::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 80% 60% at 0% 100%,rgba(212,98,26,.12) 0%,transparent 65%);
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:12px;
  font-size:.62rem;font-weight:600;letter-spacing:.32em;
  text-transform:uppercase;color:var(--warm2);
  margin-bottom:2.5rem;
  animation:fadeUp .8s .2s both;
}
.hero-eyebrow::before{content:'';width:28px;height:1px;background:var(--warm2)}
.hero-h1{
  font-size:clamp(3.8rem,6.5vw,7rem);font-weight:700;
  line-height:.88;letter-spacing:-.01em;
  color:white;margin-bottom:1.8rem;
  animation:fadeUp .8s .35s both;
}
.hero-h1 .italic{
  font-style:italic;font-weight:300;
  color:rgba(255,255,255,.35);display:block;
  letter-spacing:.04em;
}
.hero-h1 .accent{
  -webkit-text-stroke:1px var(--warm2);
  color:transparent;
}
.hero-desc{
  font-size:.9rem;line-height:1.9;
  color:rgba(255,255,255,.38);
  max-width:380px;margin-bottom:3rem;
  animation:fadeUp .8s .5s both;
}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;animation:fadeUp .8s .65s both}
.btn-fill{
  display:inline-flex;align-items:center;gap:10px;
  padding:13px 30px;
  background:white;color:var(--ink);
  font-size:.72rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  border-radius:2px;transition:all .3s;
}
.btn-fill:hover{background:var(--warm);color:white;transform:translateY(-2px);box-shadow:0 12px 32px rgba(212,98,26,.35)}
.btn-line{
  display:inline-flex;align-items:center;gap:10px;
  padding:13px 30px;
  border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.6);
  font-size:.72rem;font-weight:600;letter-spacing:.14em;text-transform:uppercase;
  border-radius:2px;transition:all .3s;
}
.btn-line:hover{border-color:white;color:white}

/* Hero stats row */
.hero-stats{
  display:flex;gap:2.5rem;margin-top:4rem;padding-top:2rem;
  border-top:1px solid rgba(255,255,255,.08);
  animation:fadeUp .8s .8s both;
}
.hstat .n{
  font-family:'Cormorant',serif;font-size:2.2rem;
  font-weight:700;color:white;line-height:1;
}
.hstat .l{
  font-size:.6rem;font-weight:600;letter-spacing:.2em;
  text-transform:uppercase;color:rgba(255,255,255,.3);margin-top:3px;
}

/* Hero right — collage */
.hero-right{
  position:relative;overflow:hidden;
  display:grid;grid-template-columns:1fr 1fr;
  grid-template-rows:1fr 1fr;
  gap:3px;background:var(--ink3);
}
.hcell{overflow:hidden;position:relative;cursor:pointer}
.hcell img{width:100%;height:100%;object-fit:cover;filter:brightness(.8) grayscale(.15);transition:all .6s var(--ease)}
.hcell:hover img{filter:brightness(1) grayscale(0);transform:scale(1.04)}
.hcell.big{grid-row:span 2}
/* Warm overlay on hover */
.hcell::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(212,98,26,.0),rgba(212,98,26,.28));
  opacity:0;transition:opacity .4s;
}
.hcell:hover::after{opacity:1}
.hero-caption{
  position:absolute;bottom:0;left:0;right:0;
  padding:1.8rem 1.5rem;z-index:2;
  background:linear-gradient(to top,rgba(0,0,0,.75) 0%,transparent 100%);
}
.hero-caption .hc1{font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:var(--warm3);font-weight:700;margin-bottom:.3rem}
.hero-caption .hc2{font-family:'Cormorant',serif;font-size:1.4rem;font-weight:600;color:white;line-height:1.1}

/* ════════════════════════════════════════
   SECTION UTILITY
════════════════════════════════════════ */
.sec{padding:4.5rem 0}
.si{max-width:1380px;margin:0 auto;padding:0 2.2rem}
.sec-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2rem;gap:1rem;flex-wrap:wrap}
.sec-title{
  font-family:'Cormorant',serif;
  font-size:clamp(1.8rem,3vw,2.6rem);font-weight:700;
  line-height:1;
}
.sec-kicker{
  font-size:.6rem;font-weight:700;letter-spacing:.3em;text-transform:uppercase;
  color:var(--warm);margin-bottom:.5rem;
}
.see-all{
  font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:var(--mid);display:flex;align-items:center;gap:5px;
  border-bottom:1px solid var(--mist);padding-bottom:1px;
  cursor:pointer;transition:color .2s,border-color .2s;white-space:nowrap;
}
.see-all:hover{color:var(--ink);border-color:var(--ink)}

/* ════════════════════════════════════════
   ANNOUNCEMENT BANDS — warm colors
════════════════════════════════════════ */
.band{
  padding:14px 0;overflow:hidden;position:relative;
}
.band-track{display:flex;gap:0;animation:ticker 22s linear infinite;white-space:nowrap;width:max-content}
.band-item{
  display:inline-flex;align-items:center;gap:1.5rem;
  padding:0 2.5rem;
  font-size:.65rem;font-weight:700;letter-spacing:.2em;
  text-transform:uppercase;white-space:nowrap;flex-shrink:0;
}
.band-sep{font-size:.5rem;opacity:.5}
.band-1{background:var(--warm);color:white}
.band-2{background:var(--ink);color:var(--warm2)}
.band-3{background:var(--warm2);color:var(--ink)}
.band-2 .band-item{color:var(--warm2)}

/* ════════════════════════════════════════
   CATEGORY CIRCLES — B&W with hover warm
════════════════════════════════════════ */
.cat-row{display:flex;gap:1.2rem;overflow-x:auto;scrollbar-width:none;padding-bottom:4px}
.cat-row::-webkit-scrollbar{display:none}
.cat-pill{
  display:flex;flex-direction:column;align-items:center;gap:8px;
  cursor:pointer;flex-shrink:0;transition:transform .25s var(--ease);
}
.cat-pill:hover{transform:translateY(-4px)}
.cat-ring{
  width:78px;height:78px;border-radius:50%;
  overflow:hidden;border:2px solid var(--mist);
  transition:border-color .3s,box-shadow .3s;
  background:var(--fog);position:relative;
}
.cat-ring img{filter:grayscale(40%);transition:filter .4s}
.cat-ring .cat-emoji{
  display:flex;align-items:center;justify-content:center;
  height:100%;font-size:2rem;
}
.cat-pill:hover .cat-ring,.cat-pill.sel .cat-ring{
  border-color:var(--warm);
  box-shadow:0 0 0 3px rgba(212,98,26,.15);
}
.cat-pill:hover .cat-ring img,.cat-pill.sel .cat-ring img{filter:grayscale(0)}
.cat-name{
  font-size:.62rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;
  color:var(--mid);transition:color .2s;text-align:center;line-height:1.2;max-width:78px;
}
.cat-pill:hover .cat-name,.cat-pill.sel .cat-name{color:var(--warm)}

/* ════════════════════════════════════════
   FLASH SALE — warm gradient
════════════════════════════════════════ */
.flash-band{
  background:linear-gradient(105deg,var(--ink) 0%,var(--ink2) 40%,#2A1200 100%);
  border-radius:var(--r2);
  padding:1.2rem 1.8rem;
  display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;
  position:relative;overflow:hidden;
  border:1px solid rgba(212,98,26,.2);
}
.flash-band::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 50% 100% at 60% 50%,rgba(212,98,26,.12) 0%,transparent 70%);
}
.fb-icon{font-size:2rem;flex-shrink:0;position:relative;z-index:1}
.fb-text{flex:1;position:relative;z-index:1}
.fb-label{font-family:'Cormorant',serif;font-size:1.4rem;font-weight:700;color:white;line-height:1}
.fb-sub{font-size:.65rem;color:rgba(255,255,255,.4);letter-spacing:.1em;margin-top:2px}
.cd{display:flex;align-items:center;gap:6px;position:relative;z-index:1}
.cd-block{
  background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);
  border-radius:var(--r);padding:8px 12px;text-align:center;min-width:48px;
  backdrop-filter:blur(4px);
}
.cd-n{display:block;font-family:'Cormorant',serif;font-size:1.3rem;font-weight:700;color:white;line-height:1}
.cd-l{display:block;font-size:.48rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.35);margin-top:2px}
.cd-sep{color:var(--warm2);font-size:1.1rem;font-weight:700;margin-bottom:4px}
.btn-warm{
  display:inline-flex;align-items:center;gap:8px;
  padding:11px 24px;background:var(--warm);color:white;
  border-radius:2px;font-size:.7rem;font-weight:700;
  letter-spacing:.12em;text-transform:uppercase;
  transition:all .3s;position:relative;z-index:1;flex-shrink:0;
}
.btn-warm:hover{background:var(--warm2);color:var(--ink);box-shadow:0 8px 24px rgba(212,98,26,.4)}

/* ════════════════════════════════════════
   PRODUCT CARD — minimal & sharp
════════════════════════════════════════ */
.pcard{
  background:var(--white);position:relative;
  cursor:pointer;transition:transform .35s var(--ease),box-shadow .35s;
  flex-shrink:0;border-radius:var(--r);overflow:hidden;
}
.pcard:hover{transform:translateY(-5px);box-shadow:0 20px 48px rgba(0,0,0,.1)}

.pcard-photos{
  position:relative;aspect-ratio:3/4;overflow:hidden;
  background:var(--fog);
}
.pcard-photos .ph-main{
  width:100%;height:100%;object-fit:cover;
  transition:opacity .45s,transform .6s var(--ease);
  display:block;
}
.pcard-photos .ph-alt{
  position:absolute;inset:0;width:100%;height:100%;object-fit:cover;
  opacity:0;transition:opacity .45s;
}
.pcard:hover .ph-alt{opacity:1}
.pcard:hover .ph-main{transform:scale(1.04)}

/* Badges */
.pcard-bgs{position:absolute;top:9px;left:9px;z-index:2;display:flex;flex-direction:column;gap:4px}
.pbg{
  display:inline-block;padding:3px 8px;border-radius:2px;
  font-size:.55rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;
}
.pbg-new{background:var(--ink);color:white}
.pbg-hot{background:var(--warm);color:white}
.pbg-promo{background:var(--warm2);color:var(--ink)}
.pbg-top{background:white;color:var(--ink);border:1px solid var(--mist)}

/* Wish */
.pcard-wish{
  position:absolute;top:9px;right:9px;z-index:2;
  width:32px;height:32px;border-radius:50%;
  background:rgba(255,255,255,.9);backdrop-filter:blur(6px);
  display:flex;align-items:center;justify-content:center;
  color:var(--pale);opacity:0;transform:scale(.7);
  transition:all .2s var(--ease);
}
.pcard-wish svg{width:15px;height:15px;display:block;stroke-width:1.8}
.pcard:hover .pcard-wish{opacity:1;transform:scale(1)}
.pcard-wish:hover,.pcard-wish.on{color:#D94040}

/* Photo strip count */
.pcard-strip{
  position:absolute;bottom:9px;right:9px;z-index:2;
  background:rgba(0,0,0,.55);color:rgba(255,255,255,.8);
  border-radius:100px;padding:2px 8px;
  font-size:.55rem;font-weight:700;letter-spacing:.06em;
}

/* Quick add */
.pcard-quick{
  position:absolute;bottom:0;left:0;right:0;z-index:2;
  background:var(--ink);color:white;
  padding:10px 12px;text-align:center;
  font-size:.65rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  transform:translateY(100%);opacity:0;
  transition:all .35s var(--ease);
  display:flex;align-items:center;justify-content:center;gap:7px;
}
.pcard:hover .pcard-quick{transform:translateY(0);opacity:1}
.pcard-quick:hover{background:var(--warm)}

/* Info */
.pcard-info{padding:11px 11px 14px}
.pcard-brand{font-size:.58rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--pale);margin-bottom:.25rem}
.pcard-name{font-size:.82rem;font-weight:500;line-height:1.3;color:var(--ink);margin-bottom:.4rem;
  display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.pcard-price{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap}
.pp-cur{font-size:.9rem;font-weight:700;color:var(--ink)}
.pp-old{font-size:.75rem;color:var(--pale);text-decoration:line-through}
.pp-disc{font-size:.6rem;font-weight:800;color:var(--warm);background:rgba(212,98,26,.1);padding:1px 6px;border-radius:2px}
.pcard-stars{display:flex;align-items:center;gap:4px;margin-top:5px}
.pcard-stars .s{font-size:.62rem;color:var(--warm2);letter-spacing:1px}
.pcard-stars .r{font-size:.6rem;color:var(--pale)}
.pcard-swatches{display:flex;gap:4px;margin-top:7px}
.psw{width:13px;height:13px;border-radius:50%;border:1px solid rgba(0,0,0,.1);cursor:pointer;transition:all .15s}
.psw:hover{transform:scale(1.4)}

/* ════════════════════════════════════════
   AUTO-SCROLL CAROUSEL
════════════════════════════════════════ */
.carousel-outer{position:relative;overflow:hidden}
.carousel-inner{
  display:flex;gap:12px;
  width:max-content;
  animation:autoScroll var(--dur,35s) linear infinite;
}
.carousel-outer:hover .carousel-inner{animation-play-state:paused}
/* Fade edges */
.carousel-outer::before,.carousel-outer::after{
  content:'';position:absolute;top:0;bottom:0;width:80px;z-index:3;pointer-events:none;
}
.carousel-outer::before{left:0;background:linear-gradient(90deg,var(--chalk),transparent)}
.carousel-outer::after{right:0;background:linear-gradient(-90deg,var(--chalk),transparent)}
/* Dark bg sections */
.sec-dark .carousel-outer::before{background:linear-gradient(90deg,var(--ink),transparent)}
.sec-dark .carousel-outer::after{background:linear-gradient(-90deg,var(--ink),transparent)}

/* Card size in carousel */
.carousel-inner .pcard{width:195px}

/* ════════════════════════════════════════
   SHOP PAGE (grid)
════════════════════════════════════════ */
.shop-wrap{max-width:1380px;margin:0 auto;padding:2rem 2.2rem;display:flex;gap:1.5rem;align-items:flex-start}
.shop-sidebar{
  width:210px;flex-shrink:0;background:white;border-radius:var(--r2);
  padding:1.2rem;position:sticky;top:80px;
  border:1px solid var(--mist);
}
@media(max-width:820px){.shop-sidebar{display:none}}
.sb-title{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.18em;color:var(--pale);margin-bottom:.8rem;margin-top:.8rem}
.sb-title:first-child{margin-top:0}
.sb-item{display:flex;align-items:center;justify-content:space-between;padding:.4rem 0;font-size:.8rem;color:var(--mid);cursor:pointer;transition:color .2s;border-bottom:1px solid var(--fog);font-weight:500}
.sb-item:last-child{border-bottom:none}
.sb-item:hover,.sb-item.on{color:var(--ink)}
.sb-item.on{font-weight:700}
.sb-count{font-size:.65rem;color:var(--pale);background:var(--fog);padding:1px 6px;border-radius:100px}
.shop-main{flex:1;min-width:0}
.shop-bar{
  display:flex;align-items:center;justify-content:space-between;
  padding:.8rem 1rem;background:white;border-radius:var(--r2);
  margin-bottom:1rem;border:1px solid var(--mist);
}
.shop-count{font-size:.75rem;color:var(--mid);font-weight:500}
.shop-sort select{
  border:1px solid var(--mist);border-radius:var(--r);
  padding:5px 10px;font-size:.75rem;font-weight:600;color:var(--ink);
  background:var(--fog);outline:none;cursor:pointer;
}
.shop-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(175px,1fr));
  gap:12px;
}
.shop-grid .pcard{width:100%}

/* ════════════════════════════════════════
   PRODUCT DETAIL MODAL
════════════════════════════════════════ */
#pdModal{
  position:fixed;inset:0;z-index:800;
  background:rgba(12,12,12,.7);backdrop-filter:blur(10px);
  display:flex;align-items:center;justify-content:center;
  padding:1rem;opacity:0;pointer-events:none;transition:opacity .3s;
}
#pdModal.on{opacity:1;pointer-events:all}
.pd-box{
  background:white;border-radius:var(--r2);
  width:100%;max-width:900px;max-height:90vh;
  display:grid;grid-template-columns:1fr 1fr;overflow:hidden;
  transform:scale(.96) translateY(16px);
  transition:transform .4s var(--ease);
}
#pdModal.on .pd-box{transform:scale(1) translateY(0)}
@media(max-width:680px){.pd-box{grid-template-columns:1fr;max-height:96vh;overflow-y:auto}}
.pd-close{
  position:absolute;top:12px;right:12px;z-index:2;
  width:36px;height:36px;border-radius:50%;
  background:rgba(255,255,255,.9);backdrop-filter:blur(8px);
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;color:var(--ink3);cursor:pointer;
  transition:all .2s;
}
.pd-close:hover{background:var(--ink);color:white}

/* Gallery */
.pd-gallery{position:relative;background:var(--fog);overflow:hidden}
.pd-main-img{width:100%;height:100%;object-fit:cover;min-height:420px;display:block}
.pd-thumbs{
  position:absolute;bottom:0;left:0;right:0;
  display:flex;gap:4px;padding:8px;
  background:linear-gradient(to top,rgba(0,0,0,.5) 0%,transparent 100%);
  overflow-x:auto;scrollbar-width:none;
}
.pd-thumbs::-webkit-scrollbar{display:none}
.pd-thumb{
  width:50px;height:60px;border-radius:3px;overflow:hidden;flex-shrink:0;
  cursor:pointer;border:2px solid transparent;transition:border-color .2s;opacity:.7;
}
.pd-thumb img{width:100%;height:100%;object-fit:cover}
.pd-thumb.on{border-color:white;opacity:1}

/* Info panel */
.pd-info{padding:2rem 1.8rem;display:flex;flex-direction:column;gap:.9rem;overflow-y:auto;max-height:90vh}
.pd-brand{font-size:.6rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--pale)}
.pd-name{font-family:'Cormorant',serif;font-size:1.8rem;font-weight:600;line-height:1.05}
.pd-price-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.pd-price{font-size:1.5rem;font-weight:700;color:var(--ink)}
.pd-old{font-size:1rem;color:var(--pale);text-decoration:line-through}
.pd-disc{background:rgba(212,98,26,.1);color:var(--warm);font-size:.65rem;font-weight:800;padding:2px 8px;border-radius:3px;letter-spacing:.06em}
.pd-divider{height:1px;background:var(--mist)}
.pd-label{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.18em;color:var(--pale);margin-bottom:.45rem}
.pd-colors{display:flex;gap:8px;flex-wrap:wrap}
.pd-color{
  width:28px;height:28px;border-radius:50%;cursor:pointer;
  border:2px solid transparent;position:relative;transition:all .2s;
}
.pd-color::after{content:'';position:absolute;inset:-4px;border-radius:50%;border:2px solid transparent;transition:border-color .2s}
.pd-color.on::after{border-color:var(--ink)}
.pd-sizes{display:flex;gap:6px;flex-wrap:wrap}
.pd-size{
  min-width:44px;height:40px;padding:0 10px;border-radius:var(--r);
  border:1.5px solid var(--mist);
  font-size:.75rem;font-weight:700;display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:all .2s;
}
.pd-size:hover{border-color:var(--ink);color:var(--ink)}
.pd-size.on{background:var(--ink);color:white;border-color:var(--ink)}
.pd-size.oos{opacity:.3;cursor:not-allowed;text-decoration:line-through}
.pd-qty{display:flex;align-items:center;gap:10px}
.pd-qbtn{
  width:34px;height:34px;border-radius:var(--r);border:1.5px solid var(--mist);
  display:flex;align-items:center;justify-content:center;font-size:1rem;color:var(--ink);
  cursor:pointer;transition:all .2s;
}
.pd-qbtn:hover{border-color:var(--ink)}
.pd-qnum{font-size:.95rem;font-weight:700;min-width:26px;text-align:center}
.pd-add{
  width:100%;padding:14px;background:var(--ink);color:white;
  border-radius:2px;font-size:.75rem;font-weight:700;
  letter-spacing:.14em;text-transform:uppercase;
  display:flex;align-items:center;justify-content:center;gap:9px;
  transition:all .3s;
}
.pd-add:hover{background:var(--warm);box-shadow:0 8px 28px rgba(212,98,26,.35)}
.pd-buy{
  width:100%;padding:14px;background:transparent;color:var(--ink);
  border:1.5px solid var(--mist);
  border-radius:2px;font-size:.75rem;font-weight:700;
  letter-spacing:.14em;text-transform:uppercase;
  display:flex;align-items:center;justify-content:center;gap:9px;
  transition:all .3s;margin-top:6px;
}
.pd-buy:hover{border-color:var(--warm2);color:var(--warm)}
.pd-desc{font-size:.82rem;line-height:1.85;color:var(--mid)}
.pd-perks{display:flex;flex-wrap:wrap;gap:.8rem}
.pd-perk{font-size:.65rem;color:var(--mid);font-weight:600;display:flex;align-items:center;gap:5px}

/* ════════════════════════════════════════
   CART DRAWER — élégant
════════════════════════════════════════ */
#cartOverlay{
  position:fixed;inset:0;z-index:690;
  background:rgba(0,0,0,.45);backdrop-filter:blur(4px);
  opacity:0;pointer-events:none;transition:opacity .3s;
}
#cartOverlay.on{opacity:1;pointer-events:all}
#cartDrawer{
  position:fixed;top:0;right:-460px;bottom:0;z-index:700;
  width:430px;max-width:100vw;background:var(--chalk);
  display:flex;flex-direction:column;
  box-shadow:-12px 0 60px rgba(0,0,0,.12);
  transition:right .45s var(--ease);
}
#cartDrawer.on{right:0}
.cart-head{
  padding:1.3rem 1.5rem;background:var(--ink);color:white;
  display:flex;align-items:center;justify-content:space-between;
  flex-shrink:0;
}
.cart-head h3{font-family:'Cormorant',serif;font-size:1.4rem;font-weight:700}
.cart-head .sub{font-size:.62rem;color:rgba(255,255,255,.4);letter-spacing:.12em;text-transform:uppercase;margin-top:1px}
.cart-xbtn{
  width:34px;height:34px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  color:rgba(255,255,255,.5);transition:all .2s;
}
.cart-xbtn:hover{background:rgba(255,255,255,.1);color:white}
.cart-body{flex:1;overflow-y:auto;padding:1.2rem 1.5rem}
.cart-empty{
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100%;gap:.8rem;color:var(--pale);text-align:center;
}
.cart-empty .ei{font-size:3.5rem;opacity:.4;margin-bottom:.3rem}
.cart-empty p{font-size:.82rem;line-height:1.7}
.ci{display:flex;gap:.9rem;padding:.9rem 0;border-bottom:1px solid var(--mist)}
.ci-img{width:68px;height:84px;border-radius:var(--r);overflow:hidden;flex-shrink:0;background:var(--fog)}
.ci-body{flex:1}
.ci-name{font-size:.82rem;font-weight:600;line-height:1.3;margin-bottom:2px}
.ci-meta{font-size:.65rem;color:var(--pale);font-weight:500}
.ci-price{font-size:.88rem;font-weight:700;color:var(--ink);margin-top:.3rem}
.ci-row{display:flex;align-items:center;justify-content:space-between;margin-top:.6rem}
.ci-qty{display:flex;align-items:center;gap:7px}
.ciqb{width:26px;height:26px;border-radius:var(--r);border:1.5px solid var(--mist);display:flex;align-items:center;justify-content:center;font-size:.85rem;cursor:pointer;transition:all .2s;font-weight:700}
.ciqb:hover{border-color:var(--ink)}
.ciqn{font-size:.82rem;font-weight:800;min-width:20px;text-align:center}
.ci-del{font-size:.65rem;color:var(--pale);cursor:pointer;font-weight:700;transition:color .2s}
.ci-del:hover{color:#D94040}
.cart-foot{padding:1.2rem 1.5rem;border-top:1px solid var(--mist);flex-shrink:0;background:white}
.cart-row{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:.8rem}
.cart-row .cl{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.16em;color:var(--pale)}
.cart-row .ca{font-family:'Cormorant',serif;font-size:1.6rem;font-weight:700;color:var(--ink)}
.cart-checkout{
  width:100%;padding:15px;background:var(--ink);color:white;border-radius:2px;
  font-size:.72rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;
  display:flex;align-items:center;justify-content:center;gap:10px;transition:all .3s;
}
.cart-checkout:hover{background:var(--warm);box-shadow:0 8px 28px rgba(212,98,26,.35)}

/* ════════════════════════════════════════
   TOAST
════════════════════════════════════════ */
#toast{
  position:fixed;bottom:1.8rem;left:50%;z-index:2000;
  transform:translateX(-50%) translateY(80px);
  background:var(--ink);color:white;
  padding:11px 22px;border-radius:2px;
  font-size:.72rem;font-weight:600;letter-spacing:.06em;
  display:flex;align-items:center;gap:9px;
  transition:transform .4s var(--ease);white-space:nowrap;
  box-shadow:0 12px 40px rgba(0,0,0,.3);
}
#toast.on{transform:translateX(-50%) translateY(0)}
#toast .tick{color:var(--warm2)}

/* ════════════════════════════════════════
   ADMIN DASHBOARD
════════════════════════════════════════ */
#adminView{display:none}
#adminView.show{display:flex;height:100vh;overflow:hidden}
.adm-sidebar{
  width:230px;flex-shrink:0;background:var(--ink);
  display:flex;flex-direction:column;overflow-y:auto;
}
.adm-logo{
  padding:1.4rem 1.2rem;border-bottom:1px solid rgba(255,255,255,.06);
  display:flex;flex-direction:column;
}
.adm-logo .al1{font-family:'Cormorant',serif;font-size:1.2rem;font-weight:700;color:white;letter-spacing:.18em;text-transform:uppercase}
.adm-logo .al2{font-size:.52rem;color:rgba(255,255,255,.2);letter-spacing:.28em;text-transform:uppercase;margin-top:2px}
.adm-logo .al-badge{margin-top:.6rem;display:inline-block;background:var(--warm);color:white;font-size:.55rem;padding:2px 8px;border-radius:2px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;align-self:flex-start}
.adm-nav{padding:.6rem 0;flex:1}
.adm-sect{padding:.4rem 1.2rem .2rem;font-size:.55rem;font-weight:800;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.2)}
.adm-item{
  display:flex;align-items:center;gap:10px;padding:.65rem 1.2rem;
  font-size:.78rem;font-weight:500;color:rgba(255,255,255,.45);
  cursor:pointer;transition:all .2s;border-right:2px solid transparent;
}
.adm-item:hover{color:white;background:rgba(255,255,255,.04);border-right-color:rgba(255,255,255,.15)}
.adm-item.on{color:white;background:rgba(212,98,26,.15);border-right-color:var(--warm)}
.adm-item svg{width:16px;height:16px;flex-shrink:0;opacity:.7}
.adm-item.on svg{opacity:1}
.adm-item .abadge{margin-left:auto;background:var(--warm);color:white;border-radius:100px;padding:1px 8px;font-size:.58rem;font-weight:800}

.adm-main{flex:1;overflow-y:auto;background:var(--smoke)}
.adm-bar{
  background:white;padding:.9rem 1.5rem;
  border-bottom:1px solid var(--mist);
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:5;
}
.adm-bar h2{font-size:.88rem;font-weight:700;letter-spacing:.04em}
.adm-actions{display:flex;gap:.6rem;align-items:center}
.btn-sm{
  display:inline-flex;align-items:center;gap:5px;
  padding:7px 14px;border-radius:var(--r);
  font-size:.7rem;font-weight:700;letter-spacing:.04em;
  transition:all .2s;cursor:pointer;
}
.btn-sm-ink{background:var(--ink);color:white}
.btn-sm-ink:hover{background:var(--warm)}
.btn-sm-ghost{border:1.5px solid var(--mist);color:var(--ink3);background:white}
.btn-sm-ghost:hover{border-color:var(--ink3)}

/* Panels */
.adm-panel{display:none;padding:1.5rem}
.adm-panel.on{display:block}

/* Stats */
.adm-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem}
@media(max-width:860px){.adm-stats{grid-template-columns:1fr 1fr}}
.asc{background:white;border-radius:var(--r2);padding:1.2rem 1.4rem;border-top:3px solid var(--ink)}
.asc.w1{border-color:var(--warm)}
.asc.w2{border-color:var(--warm2)}
.asc.w3{border-color:var(--warm3)}
.asc-n{font-family:'Cormorant',serif;font-size:2rem;font-weight:700;color:var(--ink)}
.asc-l{font-size:.62rem;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:var(--pale);margin-top:2px}
.asc-g{font-size:.68rem;color:var(--warm);font-weight:700;margin-top:.3rem}

/* Table */
.adm-table-wrap{background:white;border-radius:var(--r2);overflow:hidden;border:1px solid var(--mist)}
.adm-tbar{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.2rem;border-bottom:1px solid var(--mist)}
.adm-tsearch{
  display:flex;align-items:center;gap:6px;
  background:var(--smoke);border:1px solid var(--mist);border-radius:var(--r);padding:6px 12px;
}
.adm-tsearch input{background:none;border:none;outline:none;font-size:.78rem;color:var(--ink);width:190px}
table{width:100%;border-collapse:collapse}
thead tr{background:var(--smoke)}
th{padding:.7rem 1rem;text-align:left;font-size:.6rem;font-weight:800;text-transform:uppercase;letter-spacing:.14em;color:var(--pale)}
td{padding:.8rem 1rem;font-size:.8rem;border-bottom:1px solid var(--fog);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(0,0,0,.015)}
.td-img{width:42px;height:52px;border-radius:var(--r);overflow:hidden;background:var(--fog);flex-shrink:0}
.td-name{font-weight:700;font-size:.8rem}
.td-sub{font-size:.65rem;color:var(--pale)}
.td-price{font-weight:800;color:var(--ink)}
.stpill{display:inline-block;padding:2px 9px;border-radius:100px;font-size:.58rem;font-weight:800;letter-spacing:.06em;text-transform:uppercase}
.st-on{background:#E6F4EC;color:#166534}
.st-draft{background:#FEF9C3;color:#854D0E}
.st-out{background:#FEE2E2;color:#991B1B}
.tact{display:flex;gap:4px}
.tact-btn{
  width:28px;height:28px;border-radius:var(--r);
  display:flex;align-items:center;justify-content:center;
  border:1px solid var(--mist);color:var(--mid);
  cursor:pointer;font-size:.78rem;transition:all .2s;
}
.tact-btn:hover{border-color:var(--ink3);color:var(--ink)}

/* Cat admin grid */
.cat-admin-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:1rem}
.cag-card{background:white;border-radius:var(--r2);overflow:hidden;border:1px solid var(--mist);transition:border-color .2s}
.cag-card:hover{border-color:var(--warm)}
.cag-img{aspect-ratio:16/9;background:var(--fog);overflow:hidden}
.cag-img img{width:100%;height:100%;object-fit:cover;filter:grayscale(40%);transition:filter .3s}
.cag-card:hover .cag-img img{filter:grayscale(0)}
.cag-info{padding:.7rem}
.cag-name{font-weight:800;font-size:.82rem;margin-bottom:2px}
.cag-count{font-size:.65rem;color:var(--pale);font-weight:600}
.cag-acts{display:flex;gap:4px;margin-top:.5rem}

/* Orders */
.order-card{
  background:white;border-radius:var(--r2);padding:1rem 1.2rem;
  margin-bottom:.7rem;border:1px solid var(--mist);
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.8rem;
}
.oc-id{font-size:.62rem;color:var(--pale);font-weight:700;letter-spacing:.08em;font-family:'Cormorant',serif}
