/* ════ CAROUSELS ════ */
function buildCarousels(){
  const zone=document.getElementById('carouselsZone');
  zone.innerHTML='';
  // Coups de coeur (top rated)
  const top=PRODS.filter(p=>p.status==='active').sort((a,b)=>(b.stars||0)-(a.stars||0));
  zone.innerHTML+=carousel('✦ Nos Coups de Cœur','coup',top,'Tout',38);
  // Per category
  CATS.forEach(c=>{
    const items=PRODS.filter(p=>p.cat===c.name&&p.status==='active');
    if(!items.length)return;
    zone.innerHTML+=carousel(`${c.emoji} ${c.name}`,c.name,items,c.name,30+items.length*2.5);
  });
  // Promos
  const promos=PRODS.filter(p=>p.badge==='promo'&&p.status==='active');
  if(promos.length)zone.innerHTML+=carousel('🔥 Promotions','promo',promos,'badge:promo',25);
}

function carousel(title,id,items,filterVal,speed){
  if(!items.length)return'';
  const doubled=[...items,...items];
  const cards=doubled.map(p=>pCardHTML(p,'195px')).join('');
  const dur=Math.round(speed+items.length*3.5);
  return`
  <div class="sec" style="padding:1rem 0 2rem">
    <div class="sec-head">
      <div><div class="sec-kicker" style="font-size:.58rem;font-weight:800;letter-spacing:.3em;text-transform:uppercase;color:var(--warm)">${title}</div></div>
      <div class="see-all" onclick="filterCat('${filterVal}')">Voir tout →</div>
    </div>
    <div class="carousel-outer">
      <div class="carousel-inner" style="--dur:${dur}s">${cards}</div>
    </div>
  </div>`;
}

/* ════ PRODUCT CARD HTML ════ */
function pCardHTML(p,w='100%'){
  const pct=p.oldP?Math.round((1-p.price/p.oldP)*100):0;
  const bg=p.badge==='new'?'<span class="pbg pbg-new">Nouveau</span>':
           p.badge==='hot'?'<span class="pbg pbg-hot">Tendance</span>':
           p.badge==='promo'?`<span class="pbg pbg-promo">-${pct}%</span>`:
           p.badge==='top'?'<span class="pbg pbg-top">Top ★</span>':'';
  const stars='★'.repeat(Math.round(p.stars||4))+'☆'.repeat(5-Math.round(p.stars||4));
  const swatches=(p.cols||[]).slice(0,4).map(c=>`<div class="psw" style="background:${c}"></div>`).join('');
