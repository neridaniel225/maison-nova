/* ════ CART ════ */
function addToCart(){
  const p=curProd;if(!p)return;
  const key=`${p.id}-${pdColor}-${pdSize}`;
  const ex=cart.find(i=>i.key===key);
  if(ex)ex.qty+=pdQty;
  else cart.push({key,id:p.id,name:p.name,brand:p.brand,price:p.price,photo:p.photos?.[0]||'',col:(p.cols||[])[pdColor]||'',size:pdSize,qty:pdQty});
  syncCart();toast(`"${p.name}" ajouté !`);
  document.getElementById('pdModal').classList.remove('on');
  document.body.style.overflow='';
}
function quickAdd(id){
  const p=PRODS.find(x=>x.id===id);if(!p)return;
  const key=`${p.id}-0-${(p.sizes||['Unique'])[0]}`;
  const ex=cart.find(i=>i.key===key);
  if(ex)ex.qty++;else cart.push({key,id:p.id,name:p.name,brand:p.brand,price:p.price,photo:p.photos?.[0]||'',col:(p.cols||[])[0]||'',size:(p.sizes||['Unique'])[0],qty:1});
  syncCart();toast(`"${p.name}" ajouté !`);
}
function syncCart(){
  const total=cart.reduce((s,i)=>s+i.qty,0);
  const b=document.getElementById('cartBadge');
  b.textContent=total;b.classList.toggle('on',total>0);
  if(total>0){b.classList.add('pop');setTimeout(()=>b.classList.remove('pop'),400);}
  document.getElementById('cartSub').textContent=`${total} article${total!==1?'s':''}`;
  const amt=cart.reduce((s,i)=>s+i.price*i.qty,0);
  document.getElementById('cartTotal').textContent=amt.toLocaleString()+' FCFA';
  document.getElementById('cartFoot').style.display=cart.length?'':'none';
  const body=document.getElementById('cartBody');
  if(!cart.length){body.innerHTML=`<div class="cart-empty"><div class="ei">🛍</div><p>Votre panier est vide.<br>Explorez notre boutique !</p></div>`;return;}
  body.innerHTML=cart.map(it=>`
    <div class="ci">
      <div class="ci-img"><img src="${it.photo}" alt="${it.name}"/></div>
      <div class="ci-body">
        <div class="ci-name">${it.name}</div>
        <div class="ci-meta">${it.brand} · ${it.size}${it.col?` · <span style="display:inline-block;width:10px;height:10px;background:${it.col};border-radius:50%;vertical-align:middle;margin-left:2px"></span>`:''}</div>
        <div class="ci-price">${(it.price*it.qty).toLocaleString()} FCFA</div>
        <div class="ci-row">
          <div class="ci-qty">
            <div class="ciqb" onclick="cqb('${it.key}',-1)">−</div>
            <div class="ciqn">${it.qty}</div>
            <div class="ciqb" onclick="cqb('${it.key}',1)">+</div>
          </div>
          <div class="ci-del" onclick="cdel('${it.key}')">Supprimer</div>
        </div>
      </div>
    </div>`).join('');
}
function cqb(k,d){const i=cart.find(x=>x.key===k);if(i){i.qty=Math.max(1,i.qty+d);syncCart();}}
function cdel(k){cart=cart.filter(x=>x.key!==k);syncCart();}
