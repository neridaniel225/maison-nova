/* ════ SHOP GRID ════ */
function buildShopGrid(){
  let items=PRODS.filter(p=>p.status==='active');
  if(shopFilter==='all'){}
  else if(shopFilter.startsWith('badge:')){const b=shopFilter.slice(6);items=items.filter(p=>p.badge===b);}
  else items=items.filter(p=>p.cat===shopFilter);
  if(searchQ)items=items.filter(p=>p.name.toLowerCase().includes(searchQ)||p.brand.toLowerCase().includes(searchQ));
  if(priceFils.length)items=items.filter(p=>priceFils.some(f=>priceMatch(f,p.price)));
  if(sortMode==='pa')items.sort((a,b)=>a.price-b.price);
  else if(sortMode==='pd')items.sort((a,b)=>b.price-a.price);
  else if(sortMode==='new')items=[...items.filter(p=>p.badge==='new'),...items.filter(p=>p.badge!=='new')];
  else if(sortMode==='promo')items=[...items.filter(p=>p.badge==='promo'),...items.filter(p=>p.badge!=='promo')];
  document.getElementById('shopCount').textContent=`${items.length} article${items.length!==1?'s':''}`;
  document.getElementById('shopGrid').innerHTML=items.map(p=>pCardHTML(p,'100%')).join('');
  buildSbSizes(items);
}
function priceMatch(f,price){
  if(f==='0-15000')return price<15000;
  if(f==='15000-30000')return price>=15000&&price<30000;
  if(f==='30000-50000')return price>=30000&&price<50000;
  if(f==='50000+')return price>=50000;
  return true;
}
function buildSbCats(){
  document.getElementById('sbCats').innerHTML=[{n:'Tout',e:'✨'},...CATS.map(c=>({n:c.name,e:c.emoji}))].map(c=>`
    <div class="sb-item ${shopFilter===(c.n==='Tout'?'all':c.n)?'on':''}" onclick="filterCat('${c.n}')">
      ${c.e} ${c.n} <span class="sb-count">${c.n==='Tout'?PRODS.filter(p=>p.status==='active').length:PRODS.filter(p=>p.cat===c.n&&p.status==='active').length}</span>
    </div>`).join('');
}
function buildSbSizes(items){
  const all=[...new Set((items||PRODS).flatMap(p=>p.sizes||[]))];
  document.getElementById('sbSizes').innerHTML=all.map(s=>`<div class="sb-item">${s}</div>`).join('');
}
function buildPriceCounts(){
  const ranges=[['0-15000','pc0'],['15000-30000','pc1'],['30000-50000','pc2'],['50000+','pc3']];
  ranges.forEach(([r,id])=>{
    const el=document.getElementById(id);
    if(el)el.textContent=PRODS.filter(p=>priceMatch(r,p.price)&&p.status==='active').length;
  });
}
function togglePrice(el,r){
  el.classList.toggle('on');
  if(el.classList.contains('on'))priceFils.push(r);
  else priceFils=priceFils.filter(f=>f!==r);
  buildShopGrid();
}
function setSort(v){sortMode=v;buildShopGrid();}

